def fetchDataForSearch(inputText):

    length = len(inputText)
    return_list = []

    if length <= 0:
        return totalSearchLsit #if theres nothing in the input, just return everything
    if length <= 3:
        if inputText in totalSearchLsit:
            if inputText[0] == totalSearchLsit[0]:
                return_list.append(inputText)
